#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "[gate] validate-docs"
bin/validate-docs

echo "[gate] loc-check"
bin/loc-check

echo "[gate] rustfmt"
cargo fmt --all --check

echo "[gate] clippy"
cargo clippy --workspace --all-targets --no-deps

echo "[gate] tests"
cargo test --workspace
